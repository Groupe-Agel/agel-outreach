# Copy to .env.local and fill in values.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# With AUTH_TRUST_HOST=true NextAuth derives the base URL from the
# request Host/X-Forwarded-* headers — no NEXTAUTH_URL needed.
AUTH_TRUST_HOST="true"

# Google Cloud Console → OAuth 2.0 Client (Web app)
# Authorized redirect URI: {APP_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated allowlist of email domains permitted to sign in
AUTH_ALLOWED_DOMAINS="groupe-agel.com"

# Mail transport selection.
#   "mailpit" → local SMTP capture, see https://mailpit.axllent.org
#   "smtp"    → any SMTP server (set SMTP_HOST/PORT/USER/PASS)
#   "resend"  → production HTTP API (set RESEND_API_KEY + verified domain)
MAIL_TRANSPORT="mailpit"

SMTP_HOST="127.0.0.1"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"

# Resend account + verified sending domain (see docs/SETUP.md)
RESEND_API_KEY=""
RESEND_FROM_DOMAIN="groupe-agel.com"
RESEND_DEFAULT_FROM_EMAIL="outreach@groupe-agel.com"
RESEND_WEBHOOK_SECRET=""

# Protects /api/cron/dispatch — hit with header: x-cron-secret
CRON_SECRET=""

APP_URL="http://localhost:3000"

# Dev bypass: skip Google SSO entirely and act as dev@groupe-agel.com.
# Useful before OAuth is wired up. NEVER set in production.
DEV_SKIP_AUTH="false"
